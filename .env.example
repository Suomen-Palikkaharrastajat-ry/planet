# PocketBase configuration (Phase 1: Feed Sync)
#
# URL of the running PocketBase instance.
# Example: http://localhost:8090
# Leave unset to skip PocketBase sync and build from raw feed data (backwards-compatible fallback).
POCKETBASE_URL=

# PocketBase superuser API token (≥ 0.22 bearer token, NOT email/password).
# Generate one in the PocketBase Admin UI under Settings → API Keys.
POCKETBASE_API_KEY=
